# Choose the provider adapter explicitly: anthropic or openai.
GROK_SEARCH_RS_PROVIDER=anthropic

# Web search is enabled by default. Set false to disable provider web search.
GROK_SEARCH_RS_WEB_SEARCH=true

# x_search is disabled by default and only applies to provider=openai.
GROK_SEARCH_RS_X_SEARCH=false

# Anthropic Messages-compatible gateway.
ANTHROPIC_API_KEY=your-provider-key
ANTHROPIC_API_URL=http://127.0.0.1:8317/v1
ANTHROPIC_MODEL=grok-4-1-fast-reasoning

# OpenAI Responses-compatible gateway.
# OPENAI_API_KEY=your-provider-key
# OPENAI_API_URL=https://api.x.ai/v1
# OPENAI_MODEL=grok-4.3

# Tavily is optional but required for web_fetch, web_map, enrichment, and fallback sources.
TAVILY_API_KEY=tvly-your-key
TAVILY_API_URL=https://api.tavily.com
TAVILY_ENABLED=true

# Search source behavior.
GROK_SEARCH_RS_EXTRA_SOURCES=0
GROK_SEARCH_RS_FALLBACK_SOURCES=5
GROK_SEARCH_RS_CACHE_SIZE=256
