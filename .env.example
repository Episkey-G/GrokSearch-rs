# Grok Responses-compatible gateway. Provide root URL or /v1; endpoint is normalized automatically.
GROK_SEARCH_API_KEY=your-grok-compatible-key
GROK_SEARCH_URL=https://api.x.ai
GROK_SEARCH_MODEL=grok-4-1-fast-reasoning

# web_search is enabled by default. x_search is disabled by default.
GROK_SEARCH_WEB_SEARCH=true
GROK_SEARCH_X_SEARCH=false

# Tavily provides extra sources, URL fetch, and site map. Enabled by default when a key is present.
TAVILY_API_KEY=tvly-your-key
TAVILY_API_URL=https://api.tavily.com
# TAVILY_ENABLED=false

# Firecrawl provides fetch fallback and supplemental source fallback. Enabled by default when a key is present.
# FIRECRAWL_API_KEY=fc-your-key
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_ENABLED=false

# Search source behavior.
GROK_SEARCH_EXTRA_SOURCES=0
GROK_SEARCH_FALLBACK_SOURCES=5
GROK_SEARCH_CACHE_SIZE=256
GROK_SEARCH_TIMEOUT_SECONDS=60
